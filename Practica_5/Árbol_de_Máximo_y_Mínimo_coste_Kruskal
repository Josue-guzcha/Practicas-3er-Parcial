        ('B', 'D', 8),
        ('B', 'E', 5),
        ('C', 'E', 7),
        ('D', 'E', 9),
    ]

    arbol, costo = kruskal(nodos, aristas)
    visualizar_grafo(nodos, aristas, arbol)